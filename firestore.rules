rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userProfile() {
      return userDoc().data;
    }

    function hasUserProfile() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isStaff() {
      return hasUserProfile()
        && userProfile().role in ['admin', 'gestor', 'profissional'];
    }

    function isAdmin() {
      return hasUserProfile() && userProfile().role == 'admin';
    }

    function validEmotion(emotion) {
      return emotion in [
        'feliz',
        'cansado',
        'triste',
        'ansioso',
        'sozinho',
        'motivado',
        'sobrecarregado'
      ];
    }

    function validRisk(risk) {
      return risk in ['baixo', 'medio', 'alto'];
    }

    function validStatus(status) {
      return status in ['novo', 'em_acompanhamento', 'acolhido'];
    }

    function validUserCreate(userId) {
      return isSelf(userId)
        && request.resource.data.keys().hasAll([
          'uid', 'name', 'email', 'role', 'createdAt', 'updatedAt'
        ])
        && request.resource.data.keys().hasOnly([
          'uid', 'name', 'email', 'role', 'createdAt', 'updatedAt'
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.role == 'jovem'
        && request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;
    }

    function validOwnerCreate() {
      return signedIn() && request.resource.data.userId == request.auth.uid;
    }

    function ownsResource() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    function ownsLegacyResource() {
      return signedIn() && resource.data.uid == request.auth.uid;
    }

    match /users/{userId} {
      allow create: if validUserCreate(userId);

      allow get: if isSelf(userId) || isStaff();
      allow list: if isStaff();

      allow update: if (
        isSelf(userId)
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['name', 'updatedAt'])
          && request.resource.data.name is string
          && request.resource.data.updatedAt is timestamp
        ) || (
          isAdmin()
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['role', 'updatedAt'])
          && request.resource.data.role in ['jovem', 'profissional', 'gestor', 'admin']
          && request.resource.data.updatedAt is timestamp
        );

      allow delete: if false;
    }

    match /checkins/{checkinId} {
      allow create: if validOwnerCreate()
        && request.resource.data.keys().hasAll([
          'userId', 'userName', 'emotion', 'intensity', 'note', 'createdAt'
        ])
        && request.resource.data.keys().hasOnly([
          'userId', 'userName', 'emotion', 'intensity', 'note', 'createdAt'
        ])
        && request.resource.data.userName is string
        && validEmotion(request.resource.data.emotion)
        && request.resource.data.intensity is number
        && request.resource.data.intensity >= 1
        && request.resource.data.intensity <= 10
        && request.resource.data.note is string
        && request.resource.data.createdAt is timestamp;

      allow get, list: if ownsResource() || isStaff();

      allow update: if ownsResource()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['emotion', 'intensity', 'note', 'updatedAt'])
        && validEmotion(request.resource.data.emotion)
        && request.resource.data.intensity is number
        && request.resource.data.intensity >= 1
        && request.resource.data.intensity <= 10
        && request.resource.data.note is string
        && request.resource.data.updatedAt is timestamp;
      allow delete: if ownsResource();
    }

    match /emotionalLogs/{logId} {
      allow create: if validOwnerCreate()
        && request.resource.data.keys().hasAll([
          'userId',
          'userName',
          'text',
          'emotion',
          'risk',
          'score',
          'detectedWords',
          'supportiveMessage',
          'recommendation',
          'status',
          'createdAt'
        ])
        && request.resource.data.keys().hasOnly([
          'userId',
          'userName',
          'text',
          'emotion',
          'risk',
          'score',
          'detectedWords',
          'supportiveMessage',
          'recommendation',
          'status',
          'createdAt'
        ])
        && request.resource.data.userName is string
        && request.resource.data.text is string
        && validEmotion(request.resource.data.emotion)
        && validRisk(request.resource.data.risk)
        && request.resource.data.score is number
        && request.resource.data.detectedWords is list
        && request.resource.data.supportiveMessage is string
        && request.resource.data.recommendation is string
        && request.resource.data.status == 'novo'
        && request.resource.data.createdAt is timestamp;

      allow get, list: if ownsResource() || isStaff();

      allow update: if (
        isStaff()
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'updatedAt'])
          && validStatus(request.resource.data.status)
          && request.resource.data.updatedAt is timestamp
        ) || (
          ownsResource()
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly([
              'text',
              'emotion',
              'risk',
              'score',
              'detectedWords',
              'supportiveMessage',
              'recommendation',
              'updatedAt'
            ])
          && request.resource.data.text is string
          && validEmotion(request.resource.data.emotion)
          && validRisk(request.resource.data.risk)
          && request.resource.data.score is number
          && request.resource.data.detectedWords is list
          && request.resource.data.supportiveMessage is string
          && request.resource.data.recommendation is string
          && request.resource.data.updatedAt is timestamp
        );

      allow delete: if ownsResource() || isAdmin();
    }

    match /alerts/{alertId} {
      allow create: if validOwnerCreate()
        && request.resource.data.keys().hasAll([
          'logId',
          'userId',
          'userName',
          'risk',
          'score',
          'detectedWords',
          'status',
          'createdAt'
        ])
        && request.resource.data.keys().hasOnly([
          'logId',
          'userId',
          'userName',
          'risk',
          'score',
          'detectedWords',
          'status',
          'createdAt'
        ])
        && request.resource.data.logId is string
        && request.resource.data.userName is string
        && request.resource.data.risk in ['medio', 'alto']
        && request.resource.data.score is number
        && request.resource.data.detectedWords is list
        && request.resource.data.status == 'novo'
        && request.resource.data.createdAt is timestamp;

      allow get, list: if ownsResource() || isStaff();

      allow update: if (
        isStaff()
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'updatedAt'])
          && validStatus(request.resource.data.status)
          && request.resource.data.updatedAt is timestamp
        ) || (
          ownsResource()
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['risk', 'score', 'detectedWords', 'updatedAt'])
          && request.resource.data.risk in ['medio', 'alto']
          && request.resource.data.score is number
          && request.resource.data.detectedWords is list
          && request.resource.data.updatedAt is timestamp
        );
      allow delete: if ownsResource() || isAdmin();
    }

    match /notifications/{notificationId} {
      allow create: if signedIn()
        && (
          request.resource.data.userId == request.auth.uid
          || isStaff()
        );

      allow get, list: if ownsResource() || isStaff();

      allow update: if isStaff()
        || (
          ownsResource()
          && request.resource.data.userId == resource.data.userId
        );
      allow delete: if ownsResource() || isAdmin();
    }

    match /supportMessages/{messageId} {
      allow get, list: if signedIn();
      allow create, update, delete: if isStaff();
    }

    match /adminStats/{statId} {
      allow get, list: if isStaff();
      allow create, update, delete: if isAdmin();
    }

    match /systemConfig/{configId} {
      allow get, list: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    // Compatibilidade com a primeira versao do projeto.
    match /usuarios/{userId} {
      allow create: if isSelf(userId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email;

      allow get: if isSelf(userId) || isStaff();
      allow list: if isStaff();

      allow update: if isSelf(userId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email;

      allow delete: if false;
    }

    // Compatibilidade com relatos antigos.
    match /relatos/{relatoId} {
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid;

      allow get: if ownsLegacyResource() || isStaff();
      allow list: if isStaff();

      allow update: if isStaff()
        || (
          ownsLegacyResource()
          && request.resource.data.uid == resource.data.uid
        );
      allow delete: if ownsLegacyResource() || isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
